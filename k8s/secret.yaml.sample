# Create with: kubectl create secret generic email-mcp-accounts --from-file=accounts.json=./accounts.json
#
# Or copy this file to secret.yaml, fill in your accounts.json content under
# stringData, and apply it. secret.yaml is gitignored so real credentials
# never get committed.
apiVersion: v1
kind: Secret
metadata:
  name: email-mcp-accounts
type: Opaque
stringData:
  accounts.json: |
    {
      "send_code": "",
      "accounts": [
        {
          "name": "personal",
          "address": "me@example.com",
          "password": "your-app-password",
          "provider": "gmail"
        }
      ]
    }
